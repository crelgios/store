# Supabase Project Settings
# Get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_SESSION_SECRET=use-a-long-random-secret-here

# Store settings shown during manual UPI checkout
NEXT_PUBLIC_STORE_NAME=Aliwvide Store
NEXT_PUBLIC_SITE_URL=https://store.aliwvide.com
NEXT_PUBLIC_UPI_ID=aliwvidestore@upi
NEXT_PUBLIC_UPI_QR_URL=
# Your store/admin WhatsApp number in international format, no + sign. Example for India: 919876543210
# WhatsApp floating button and checkout order redirect number. Use country code without +, e.g. 919876543210
NEXT_PUBLIC_STORE_WHATSAPP_NUMBER=
DELIVERY_CHARGE=99
NEXT_PUBLIC_DELIVERY_CHARGE=99

# Optional: enables automatic background removal for AI Store Manager raw product uploads.
# Without this key, images are still resized, centered, compressed, converted to WebP, and uploaded.
REMOVEBG_API_KEY=
